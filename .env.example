# Copy this file to .env and fill in your values
# Do NOT commit .env to version control

# Flask secret key for session management (generate a random string)
FLASK_SECRET_KEY=change-me-to-a-random-string

# Tabletop.Events API key
TTE_API_KEY=your-api-key-here

# Set to 1 to enable Flask debug mode (do not use in production)
FLASK_DEBUG=0

# Directory for server-side session files
SESSION_FILE_DIR=flask_session
